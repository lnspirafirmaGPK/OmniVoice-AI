NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
API_VERSION=v1
DEFAULT_TENANT_ISOLATION_MODE=row_level

OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_LLM_MODEL=gpt-5
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

DEFAULT_LANGUAGE=th
ENABLE_EXTERNAL_TTS=true
SAVE_TTS_AUDIO_TO_PUBLIC=true

TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_GATHER_TIMEOUT=4
TWILIO_GATHER_HINTS=
TWILIO_USE_EXTERNAL_TTS=false
TWILIO_STATUS_CALLBACK_URL=/api/webhooks/twilio/status

TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_VALIDATE_SIGNATURE=false
TELNYX_SPEAK_VOICE=Telnyx.KokoroTTS.af
TELNYX_LANGUAGE=th
TELNYX_USE_AI_GATHER=true

SIP_SHARED_SECRET=
SIP_PROVIDER_NAME=generic-sip

DEFAULT_STORE_NAME=OmniVoice AI Demo Store
DEFAULT_CURRENCY=THB
SALES_HANDOFF_EMAIL=sales@example.com
APPOINTMENT_TIMEZONE=Asia/Bangkok
